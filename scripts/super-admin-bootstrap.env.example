# Run `node scripts/bootstrap-super-admin-password.js`
#
# Notes:
# - Keep these values out of git.
# - SUPABASE_SERVICE_ROLE_KEY is required because we update Auth users server-side.
#

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Target user
SUPER_ADMIN_EMAIL=itbaitalshaar@gmail.com

# New password to set (required)
SUPER_ADMIN_PASSWORD=ChangeMeToSomethingStrong

