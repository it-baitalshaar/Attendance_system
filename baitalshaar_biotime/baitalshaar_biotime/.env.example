# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# BioTime device API (required)
BIOTIME_BASE_URL=http://192.168.1.50:80
BIOTIME_USERNAME=admin
BIOTIME_PASSWORD=your-password

# App
PORT=5173
BIOTIME_SYNC_TARGET=office

# Optional: transaction path if device uses /iclock
# BIOTIME_TRANSACTION_PATH=/iclock/api/transactions/

# Optional: full sync once, or debug invalid transactions
# BIOTIME_FULL_SYNC=1
# BIOTIME_DEBUG_INVALID=1
