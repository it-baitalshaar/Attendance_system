# copy this to a `.env` file on the machine that can reach BioTime locally
# and fill in your real values.

## Supabase (service-role key required for writes)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

## BioTime (the base URL that is accessible from *this* computer)
BIOTIME_BASE_URL="http://192.168.1.50:80"

# optional header if your BioTime API is protected:
# BIOTIME_AUTH_HEADER="Bearer ..."

# --------- authentication helper (not required for the sync script) ---------
# the `scripts/get-auth-token.js` script reads these values and POSTs to
# /jwt-api-token-auth/ and /api-token-auth/; set them only if you want to
# obtain a bearer token for other API calls.
# BASE_URL="http://your-biometric-server:8097"    # e.g. the same host as
#                                                   # the docs you linked
# BIOTIME_USERNAME="admin"
# BIOTIME_PASSWORD="Dns@2020"
